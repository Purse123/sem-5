#include <opencv2/opencv.hpp>
#include <iostream>

int main() {
  // #############################################
  //              OpenCV stuffs
  // #############################################
  /**
     @brief Loads an image from a file.
     @anchor imread
     returns OpenCV matrix.
     If cannot be read the function returns an empty matrix.
     @param filename Name of the file to be loaded.
     @param flags Flag that can take values cv::ImreadModes, default cv::IMREAD_COLOR_BGR.
  */
  cv::Mat img = cv::imread("doom.png", cv::IMREAD_COLOR_BGR);
  
  // #############################################
  //         My Blobs, Experiments
  // #############################################
  uchar* pointer_to_first_byte = img.data;
  int rows = img.rows;
  int cols = img.cols;
  
  std::vector<int> pixel_matrix(rows * cols);
  std::vector<int> gray_matrix(rows * cols);
  
  // Trying to access pixel as raw array
  // for (int i = 0; i < rows * cols; i++) {
    // uchar value = pointer_to_first_byte[i];
      
    // int temp = std::max(0, std::min(255, static_cast<int>(value)));
    // pixel_matrix.push_back(value);
  // }

  uchar* data = img.data;
  for (int r = 0; r < rows; r++) {
    for (int c = 0; c < cols; c++) {
      int idx = (r * cols + c) * 3;

      uchar B = data[idx + 0];
      uchar G = data[idx + 1];
      uchar R = data[idx + 2];

      float intensity = 0.114f * B + 0.587f * G + 0.299f * R;
      
      gray_matrix[r*cols + c] = static_cast<int>(intensity);
    }
  }

  cv::Mat gray_img(rows, cols, CV_8UC1, gray_matrix.data());
  
  // #############################################
  //                    GUI
  // #############################################
  cv::imshow("mehh", img);
  // cv::imshow("mehh", gray_img);
  
  // #############################################
  //               Event Handler
  // #############################################
  while (true) {
    int key = cv::waitKey(0);
    if (key == 27) break;
  }

  // #############################################
  //           Destroy window & pointers
  // #############################################
  cv::destroyAllWindows();
  return 0;
}
